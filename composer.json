{
    "name":  "anibalealvarezs/meta-hub-driver",
    "description":  "APIs-Hub driver for Meta (Facebook & Instagram) integration.",
    "license":  "MIT",
    "require":  {
                    "anibalealvarezs/api-client-skeleton":  "dev-main",
                    "anibalealvarezs/api-driver-core":  "dev-main",
                    "anibalealvarezs/facebook-graph-api":  "dev-main",
                    "symfony/http-foundation":  "^5.4 || ^6.0 || ^7.0",
                    "psr/log":  "^1.0 || ^2.0 || ^3.0",
                    "nesbot/carbon":  "^2.0 || ^3.0",
                    "fakerphp/faker":  "^1.20",
                    "doctrine/orm":  "^2.12.3 || ^3.0",
                    "php":  ">=8.3"
                },
    "repositories":  [
                         {
                             "type":  "composer",
                             "url":  "https://satis.anibalalvarez.com/"
                         }
                     ],
    "autoload":  {
                     "psr-4":  {
                                   "Anibalealvarezs\\MetaHubDriver\\":  "src/"
                               }
                 },
    "minimum-stability":  "dev",
    "require-dev":  {
                        "doctrine/instantiator":  "^1.5",
                        "phpunit/phpunit":  "9.6"
                    },
    "config":  {
                   "platform":  {
                                    "php":  "8.3.0"
                                }
               },
    "prefer-stable":  true
}