{
  "name": "anibalealvarezs/meta-hub-driver",
  "description": "APIs-Hub driver for Meta (Facebook & Instagram) integration.",
  "license": "MIT",
  "authors": [
    {
      "name": "Aníbal Álvarez",
      "email": "anibalealvarezs@gmail.com"
    }
  ],
  "require": {
    "anibalealvarezs/api-client-skeleton": "^1.0.0",
    "anibalealvarezs/api-driver-core": "^1.0.0",
    "anibalealvarezs/facebook-graph-api": "^1.0.0",
    "symfony/http-foundation": "^5.4 || ^6.0 || ^7.0",
    "psr/log": "^1.0 || ^2.0 || ^3.0",
    "nesbot/carbon": "^2.0 || ^3.0",
    "fakerphp/faker": "^1.20",
    "doctrine/orm": "^2.12.3 || ^3.0",
    "php": ">=8.3"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://satis.anibalalvarez.com/"
    }
  ],
  "autoload": {
    "psr-4": {
      "Anibalealvarezs\\MetaHubDriver\\": "src/"
    }
  },
  "minimum-stability": "dev",
  "require-dev": {
    "phpunit/phpunit": "9.6",
    "doctrine/instantiator": "^1.5"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "prefer-stable": true
}